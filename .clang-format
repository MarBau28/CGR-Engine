---
Language: Cpp
BasedOnStyle: LLVM

# Braces: Same line for functions, namespaces, and classes (OTBS)
BreakBeforeBraces: Attach

# Indentation
IndentWidth: 4
ColumnLimit: 100
NamespaceIndentation: All

# Spacing Logic (The "Breathing Room" Rules)
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false

# Alignment (Makes OpenGL buffer/attribute blocks look clean)
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: true
AlignConsecutiveDeclarations: false

# Space before parens (standard C++ look)
SpaceBeforeParens: ControlStatements

# Namespace Comments (Disables the trailing '// namespace X' comments)
FixNamespaceComments: false